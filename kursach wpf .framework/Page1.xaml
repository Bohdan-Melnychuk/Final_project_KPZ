<Page
    x:Class="kursach_wpf.framework.Page1"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:kursach_wpf.framework"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="Page1"
    d:DesignHeight="400"
    d:DesignWidth="600"
    mc:Ignorable="d">

    <Grid>
        <!--  Теплий коричневий фоновий градієнт  -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#1A0F0A" />
                <GradientStop Offset="0.5" Color="#2D1B0E" />
                <GradientStop Offset="1" Color="#3E2723" />
            </LinearGradientBrush>
        </Grid.Background>

        <!--  Шахматний паттерн у теплих тонах  -->
        <Grid Opacity="0.15">
            <Grid.Background>
                <DrawingBrush
                    TileMode="Tile"
                    Viewport="0,0,40,40"
                    ViewportUnits="Absolute">
                    <DrawingBrush.Drawing>
                        <DrawingGroup>
                            <GeometryDrawing Brush="#8B4513">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="0,0,20,20" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                            <GeometryDrawing Brush="#8B4513">
                                <GeometryDrawing.Geometry>
                                    <RectangleGeometry Rect="20,20,20,20" />
                                </GeometryDrawing.Geometry>
                            </GeometryDrawing>
                        </DrawingGroup>
                    </DrawingBrush.Drawing>
                </DrawingBrush>
            </Grid.Background>
        </Grid>

        <!--  Основний контейнер  -->
        <Border
            Width="450"
            Height="280"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Background="#CC3E2723"
            BorderThickness="3"
            CornerRadius="20">
            <Border.BorderBrush>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Offset="0" Color="#CD853F" />
                    <GradientStop Offset="0.5" Color="#F5DEB3" />
                    <GradientStop Offset="1" Color="#A0522D" />
                </LinearGradientBrush>
            </Border.BorderBrush>
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="15"
                    Direction="315"
                    Opacity="0.7"
                    ShadowDepth="8"
                    Color="#3E2723" />
            </Border.Effect>

            <Grid>
                <Viewbox
                    Width="85"
                    Height="90"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top">
                    <Canvas Width="100" Height="120">
                        <!--  Широка плоска основа  -->

                        <!--  Нижня частина (широка)  -->
                        <Path Data="M20,105 Q20,95 25,90 L75,90 Q80,95 80,105 Z" Fill="#CD853F" />

                        <!--  Основне тіло короля (конусоподібне)  -->
                        <Path Data="M25,90 Q30,75 35,65 L65,65 Q70,75 75,90 Z" Fill="#8B4513" />

                        <!--  Верхня частина тіла  -->
                        <Ellipse
                            Canvas.Left="35"
                            Canvas.Top="55"
                            Width="30"
                            Height="18"
                            Fill="#F5DEB3" />

                        <!--  Шия/перехід до корони  -->
                        <Rectangle
                            Canvas.Left="42"
                            Canvas.Top="45"
                            Width="16"
                            Height="15"
                            Fill="#8B4513"
                            RadiusX="8"
                            RadiusY="8" />

                        <!--  Корона (округла основа)  -->
                        <Ellipse
                            Canvas.Left="38"
                            Canvas.Top="35"
                            Width="24"
                            Height="16"
                            Fill="#CD853F" />

                        <!--  Верхня частина корони  -->
                        <Rectangle
                            Canvas.Left="45"
                            Canvas.Top="25"
                            Width="10"
                            Height="18"
                            Fill="#8B4513"
                            RadiusX="5"
                            RadiusY="5" />

                        <!--  Хрест на вершині  -->
                        <Rectangle
                            Canvas.Left="48.5"
                            Canvas.Top="15"
                            Width="3"
                            Height="15"
                            Fill="#8B4513" />
                        <Rectangle
                            Canvas.Left="43"
                            Canvas.Top="20"
                            Width="14"
                            Height="3"
                            Fill="#8B4513" />

                        <!--  Декоративна смужка  -->
                        <Rectangle
                            Canvas.Left="25"
                            Canvas.Top="88"
                            Width="50"
                            Height="2"
                            Fill="#F5DEB3" />

                        <!--  Центральна декоративна лінія  -->
                        <Ellipse
                            Canvas.Left="47"
                            Canvas.Top="70"
                            Width="6"
                            Height="4"
                            Fill="#CD853F" />

                        <!--  Тінь  -->
                        <Ellipse
                            Canvas.Left="12"
                            Canvas.Top="117"
                            Width="76"
                            Height="8"
                            Fill="#663E2723"
                            Opacity="0.4" />
                    </Canvas>
                </Viewbox>

                <!--  Лейбл переможця  -->
                <Label
                    Name="WinLuse"
                    Width="350"
                    Height="84"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Content="НІЧИЯ"
                    FontFamily="Segoe UI Black"
                    FontSize="28"
                    FontWeight="Bold"
                    IsEnabled="False">
                    <Label.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#F5DEB3" />
                            <GradientStop Offset="0.5" Color="#DDBF94" />
                            <GradientStop Offset="1" Color="#CD853F" />
                        </LinearGradientBrush>
                    </Label.Foreground>
                    <Label.Effect>
                        <DropShadowEffect
                            BlurRadius="5"
                            Direction="270"
                            Opacity="0.8"
                            ShadowDepth="3"
                            Color="#3E2723" />
                    </Label.Effect>
                </Label>

                <!--  Кнопка виходу  -->
                <Button
                    Width="150"
                    Height="50"
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Click="Button_Click"
                    Content="ВИХІД"
                    Cursor="Hand"
                    FontFamily="Segoe UI Semibold"
                    FontSize="18"
                    FontWeight="Bold">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border
                                x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderThickness="2"
                                CornerRadius="25">
                                <Border.BorderBrush>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Offset="0" Color="#CD853F" />
                                        <GradientStop Offset="1" Color="#A0522D" />
                                    </LinearGradientBrush>
                                </Border.BorderBrush>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#A0522D" />
                                                <GradientStop Offset="1" Color="#8B4513" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="ButtonBorder" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Offset="0" Color="#654321" />
                                                <GradientStop Offset="1" Color="#5D4037" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <Button.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#8B4513" />
                            <GradientStop Offset="1" Color="#654321" />
                        </LinearGradientBrush>
                    </Button.Background>
                    <Button.Foreground>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#F5DEB3" />
                            <GradientStop Offset="1" Color="#CD853F" />
                        </LinearGradientBrush>
                    </Button.Foreground>
                    <Button.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Direction="270"
                            Opacity="0.6"
                            ShadowDepth="4"
                            Color="#3E2723" />
                    </Button.Effect>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Page>